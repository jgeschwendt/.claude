#!/usr/bin/env bash
set -euo pipefail

branch="$(git symbolic-ref --short -q HEAD)" || { echo "refuse: detached HEAD"; exit 1; }
[[ "$branch" == "main" ]] || { echo "refuse: not on main ($branch)"; exit 1; }

git add --all

if ! git diff --cached --quiet; then
	today="$(date +%m/%d/%y)"
	last="$(git log -1 --format=%cd --date=format:%m/%d/%y 2>/dev/null || true)"
	if [[ "$today" == "$last" ]]; then
		git commit --amend --no-edit
	else
		git commit --message "update: ${today}"
	fi
fi

git push --force-with-lease origin "$branch"
